# macOS
.DS_Store

# Python
__pycache__/
*.pyc
.venv/
venv/

# Heavy raw / intermediate data — re-derivable from ANAC + the build script.
# Only the small derived files needed by build_html.py are kept (see force-includes below).
raw/*

# Force-include the small build inputs (embedded into the HTMLs by build_html.py).
!raw/italy_regions.geojson
!raw/italia_places.json

# Local Claude harness state — don't ship.
.claude/settings.local.json
